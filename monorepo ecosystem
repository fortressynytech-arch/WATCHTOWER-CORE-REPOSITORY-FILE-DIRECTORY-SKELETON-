import time

class SanctuarySchedulerMesh:
    def __init__(self, tenant_id="YNY_FAMILY_CORE"):
        self.tenant_id = tenant_id
        self.calendar_events_ledger = []
        self.active_asset_locks = {} # Tracks laundry, kitchen, and room reservations

    def request_shared_asset_reservation(self, requestor_name, asset_name_key, start_epoch, duration_hours):
        """
        [Logistics Core] Enforces absolute multi-user scheduling clarity. Blocks 
        family timeline conflicts (e.g., dual laundry loads or kitchen clashes).
        """
        current_time = time.time()
        duration_seconds = float(duration_hours) * 3600.0
        end_epoch = float(start_epoch) + duration_seconds
        
        asset_key = str(asset_name_key).upper()
        
        # 1. Conflict Prevention Evaluation Loop
        if asset_key in self.active_asset_locks:
            for active_lock in self.active_asset_locks[asset_key]:
                # Check if requested time blocks physically collide with an existing reservation
                if not (end_epoch <= active_lock["start"] or float(start_epoch) >= active_lock["end"]):
                    return {
                        "reservation_granted": False,
                        "error_reason": "ASSET_RESERVATION_CONFLICT",
                        "conflicting_tenant": active_lock["user"],
                        "remedy_instruction": f"Time slot unavailable. [{active_lock['user']}] has locked the {asset_key} until this period clears."
                    }
                    
        # 2. Grant Conflict-Free Reservation Lock
        lock_packet = {"user": requestor_name, "start": float(start_epoch), "end": end_epoch}
        if asset_key not in self.active_asset_locks:
            self.active_asset_locks[asset_key] = []
            
        self.active_asset_locks[asset_key].append(lock_packet)
        print(f"🟩 SANCTUARY LOCK: [{requestor_name}] has successfully locked shared asset [{asset_key}].")
        
        return {
            "reservation_granted": True,
            "status": "ASSET_LOCKED_SECURE",
            "time_window_duration_hours": duration_hours
        }

